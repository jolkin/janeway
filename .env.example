# Copy this file to `.env` and uncomment the variables you want to override.
# `docker compose up` reads `.env` automatically.

# Start the visualization frontend (Vite) at http://localhost:5173.  When the
# drone scene is open, the visualization acts as the execution oracle and
# drives the dispatch loop as actions visually complete.
# ENABLE_VIS=1

# Enable the in-container simulated oracle to drive the dispatch loop
# autonomously, without any external client.  When this is unset (the
# default), the dispatcher accepts plans but waits for execution reports
# from outside the container — typically posted by the visualization
# (ENABLE_VIS=1) or by the ROS 2 bridge on http://localhost:9000.
# Setting BOTH ENABLE_ORACLE=1 and ENABLE_VIS=1 results in two independent
# sources of execution reports racing into the dispatcher; choose one.
# ENABLE_ORACLE=1

# Inject blanket-negation faults from the oracle for every causal link.
# See README "Scenarios → Fault injection" for spec-driven faults.
# SIMULATE_FAULTS=1

# Path (on the host, relative to this file) to a YAML/JSON fault spec.
# Requires a docker-compose.override.yml entry that mounts the file at
# /app/faults.yaml — see docker-compose.yml header for the snippet.
# FAULT_SPEC_FILE=/app/faults.yaml

# URL to POST {"status": "completed"|"fail"} to when a mission terminates.
# MISSION_STATUS_CALLBACK_URL=http://host.docker.internal:9100/mission-status

# Override the WebSocket URL the browser uses to reach the telemetry server.
# Only needed when the visualization is served from a CDN or reverse proxy
# that can't forward the /ws path back into the container.
# VIS_WS_URL=wss://example.com/ws

# Drone-scene preset selector.  `single` renders 1 drone + 2 houses (matches
# examples/pddl/drone_problem.pddl); `multi` renders 2 drones + 3 houses
# (matches examples/pddl/drone_problem_multi.pddl).  Unset uses the JSON
# default in pykirk/visualization/src/config/scene-config.json (currently
# `multi`).
# VIS_DRONE_PRESET=single
